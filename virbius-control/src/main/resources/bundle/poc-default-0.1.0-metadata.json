{
  "scope": {
    "tenants": ["default"],
    "scenes": ["general_chat", "medical_qa"]
  },
  "gateway": {
    "evaluate": true,
    "fail_mode": "open",
    "cloud_scan": {
      "agent_url": "http://127.0.0.1:9070",
      "timeout_ms": 3000
    },
    "routes": [
      {
        "scene": "general_chat",
        "uri": "/v1/chat/completions",
        "methods": ["POST"],
        "priority": 0
      },
      {
        "scene": "medical_qa",
        "uri": "/v1/chat/completions",
        "methods": ["POST"],
        "priority": 10,
        "match": {
          "headers": {
            "X-Virbius-Scene": "medical_qa"
          }
        }
      }
    ]
  },
  "context_bindings": {
    "version": 1,
    "vars": {
      "app_id": { "from": "header", "name": "X-App-Id" },
      "debug_flag": { "from": "query", "name": "debug" },
      "model_name": { "from": "query", "name": "model" }
    }
  }
}
