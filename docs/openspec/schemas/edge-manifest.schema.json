{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://virbius.io/schemas/edge-manifest/v1/mvp",
  "title": "VirbiusEdgeManifest",
  "description": "端侧 SDK 清单：rules[] 含 rollout/enforce 快照 + sdk_config（ingest、采样）。Edge 拉取 Bearer（edge_api_key）在 Init 配置，不在本 manifest 内。",
  "type": "object",
  "required": ["tenant_id", "manifest_version", "rules", "sdk_config"],
  "properties": {
    "tenant_id": { "type": "string" },
    "app_id": {
      "type": "string",
      "description": "Per-app manifest owner; SDK validates against VIRBIUS_APP_ID"
    },
    "manifest_version": { "type": "string", "const": "1" },
    "artifact_revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonic revision; SDK compares via policy-version API"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 instant when this manifest was published"
    },
    "bundle_id": { "type": "string" },
    "bundle_version": { "type": "string" },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/edgeRule" }
    },
    "dlp_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/dlpRule" }
    },
    "sdk_config": { "$ref": "#/$defs/sdkConfig" },
    "lists": {
      "type": "object",
      "description": "legacy 关键词名单（兼容 content-lists.json）",
      "properties": {
        "tenant_id": { "type": "string" },
        "deny": { "$ref": "#/$defs/keywordSide" },
        "allow": { "$ref": "#/$defs/keywordSide" }
      }
    }
  },
  "$defs": {
    "keywordSide": {
      "type": "object",
      "properties": {
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "edgeRule": {
      "type": "object",
      "required": [
        "rule_id",
        "rule_revision",
        "reason_code",
        "risk_score",
        "intent_action",
        "enforce_mode",
        "rollout_state"
      ],
      "properties": {
        "rule_id": { "type": "string" },
        "rule_revision": { "type": "integer", "minimum": 1 },
        "reason_code": { "type": "string" },
        "risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "intent_action": {
          "type": "string",
          "enum": ["allow", "deny", "captcha", "review"]
        },
        "enforce_mode": {
          "type": "string",
          "enum": ["dry_run", "canary", "full"]
        },
        "rollout_state": {
          "type": "string",
          "enum": ["draft", "disabled", "dry_run", "canary", "full"]
        },
        "canary_percent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "body": {
          "oneOf": [{ "type": "object" }, { "type": "string" }]
        }
      }
    },
    "dlpRule": {
      "type": "object",
      "required": [
        "rule_id",
        "rule_revision",
        "reason_code",
        "risk_score",
        "intent_action",
        "enforce_mode",
        "rollout_state"
      ],
      "properties": {
        "rule_id": { "type": "string" },
        "rule_revision": { "type": "integer", "minimum": 1 },
        "reason_code": { "type": "string" },
        "risk_score": { "type": "integer", "const": 0 },
        "intent_action": { "type": "string", "const": "allow" },
        "enforce_mode": {
          "type": "string",
          "enum": ["dry_run", "canary", "full"]
        },
        "rollout_state": {
          "type": "string",
          "enum": ["draft", "disabled", "dry_run", "canary", "full"]
        },
        "canary_percent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "body": {
          "type": "object",
          "required": ["entity_type"],
          "properties": {
            "entity_type": {
              "type": "string",
              "enum": ["idcard_cn", "phone_cn", "email", "bank_card_cn", "custom_regex"]
            },
            "pattern": { "type": "string" },
            "mask_template": { "type": "string" },
            "priority": { "type": "integer" }
          }
        }
      }
    },
    "sdkConfig": {
      "type": "object",
      "description": "运行时行为配置。不含 edge_api_key（Control 拉取凭证，见 EdgeInitConfig / DESIGN §8.10.2.5a）。",
      "properties": {
        "audit_ingest_url": { "type": "string", "format": "uri" },
        "audit_ingest_token": { "type": "string" },
        "audit_sample_rate_allow": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.1
        },
        "audit_sample_rate_hit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "audit_flush_interval_ms": { "type": "integer", "default": 30000 },
        "audit_queue_max": { "type": "integer", "default": 500 },
        "canary_session_key": {
          "type": "string",
          "enum": ["device_id", "install_id", "user_id"],
          "default": "device_id"
        },
        "dlp_vault_ttl_ms": {
          "type": "integer",
          "minimum": 1000,
          "default": 1800000
        }
      }
    },
    "fileEntry": {
      "type": "object",
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "sha256": { "type": "string" },
        "rule_id": { "type": "string" },
        "rule_revision": { "type": "integer" }
      }
    }
  }
}
