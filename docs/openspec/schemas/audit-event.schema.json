{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://virbius.io/schemas/audit-event/v1/mvp",
  "title": "VirbiusAuditEvent",
  "description": "MVP 审计事件。各执行面 publish 至消息总线（默认 Redis Stream virbius:audit:events，可选 Kafka virbius.audit.events），由 AuditIngest 入库；PoC 可同时写本地 jsonl 备档。不记录 bundle_id/bundle_version。ControlContext（F-11）：trace_id 必填；user_id/device_id 若 App 提供则各层应写入。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "tenant_id",
    "scene",
    "layer",
    "rule_id",
    "rule_revision",
    "reason_code",
    "effective_action",
    "max_risk_score",
    "intercepted_at"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "description": "App 生成的全局唯一 ID（UUID v4 或 ULID）；端 block 审计必填"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "scene": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": ["edge", "gateway", "cloud"]
    },
    "rule_id": {
      "type": "string",
      "minLength": 1
    },
    "rule_revision": {
      "type": "integer",
      "minimum": 1
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "effective_action": {
      "type": "string",
      "enum": ["allow", "block", "captcha", "review"]
    },
    "max_risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "intercepted_at": {
      "type": "string",
      "format": "date-time"
    },
    "rollout_state": {
      "type": "string",
      "enum": ["draft", "disabled", "dry_run", "canary", "full"],
      "description": "R2a+ 推荐；决策时规则运营状态"
    },
    "canary_percent": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "rollout_state=canary 或 enforce_mode=canary 时"
    },
    "in_canary_bucket": {
      "type": "boolean",
      "description": "canary 放量时是否在分桶内"
    },
    "degraded": {
      "type": "boolean",
      "description": "fail-open 等降级路径"
    },
    "user_id": {
      "type": "string",
      "maxLength": 256,
      "description": "可选；与 ControlContext / virbius_scan_ctx 一致（F-11）"
    },
    "device_id": {
      "type": "string",
      "maxLength": 256,
      "description": "可选；与 ControlContext / virbius_scan_ctx 一致（F-11）"
    },
    "trace_id_source": {
      "type": "string",
      "enum": ["client", "sdk", "gateway"],
      "description": "trace_id 来源（F-10）；建议各层写入"
    },
    "sampled_allow": {
      "type": "boolean",
      "description": "edge allow 采样命中时为 true，供 metrics rollup 外推分母"
    },
    "sample_rate_allow": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "采样时使用的 allow 采样率（默认 0.1）"
    }
  }
}
