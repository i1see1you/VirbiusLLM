{
  "tenant_id": "default",
  "manifest_version": "1",
  "app_id": "demo-app",
  "rules": [
    {
      "rule_id": "demo_deny_jailbreak",
      "rule_revision": 1,
      "reason_code": "EDGE_JAILBREAK",
      "risk_score": 100,
      "intent_action": "deny",
      "enforce_mode": "full",
      "rollout_state": "full",
      "body": {
        "list_type": "deny",
        "keywords": ["jailbreak", "DAN"]
      }
    },
    {
      "rule_id": "demo_dry_run_hint",
      "rule_revision": 1,
      "reason_code": "EDGE_DRY_HINT",
      "risk_score": 80,
      "intent_action": "deny",
      "enforce_mode": "dry_run",
      "rollout_state": "dry_run",
      "body": {
        "list_type": "deny",
        "keywords": ["ignore previous"]
      }
    }
  ],
  "dlp_rules": [
    {
      "rule_id": "demo_dlp_phone",
      "rule_revision": 1,
      "reason_code": "DLP_PHONE_CN",
      "risk_score": 0,
      "intent_action": "allow",
      "enforce_mode": "full",
      "rollout_state": "full",
      "body": {
        "entity_type": "phone_cn"
      }
    }
  ],
  "sdk_config": {
    "dlp_vault_ttl_ms": 300000,
    "canary_session_key": "device_id"
  },
  "lists": {
    "tenant_id": "default",
    "deny": { "keywords": ["jailbreak", "DAN", "ignore previous"] },
    "allow": { "keywords": [] }
  }
}
